# URL of the deployed OmniRAG backend (FastAPI).
#
# NOTE: this value is currently hardcoded as a build-time constant in next.config.ts
# (via the `env` field) and will override whatever you set here or in .env.local —
# that was deliberate, to eliminate a prior production bug where Vercel builds picked
# up the wrong URL. If you need to point local dev at a different backend (e.g. a
# locally-running one on http://localhost:8000), edit next.config.ts directly; setting
# this file or .env.local alone will silently have no effect.
NEXT_PUBLIC_API_URL=http://localhost:8000
