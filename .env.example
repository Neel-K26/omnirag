# --- Backend (FastAPI) ---
GROQ_API_KEY=
COHERE_API_KEY=

# Comma-separated list of allowed CORS origins (exact matches, no wildcards).
# Local dev default shown; in production set this to your deployed frontend URL(s),
# e.g. https://omnirag.vercel.app,https://omnirag.com
FRONTEND_URL=http://localhost:3000

# --- Frontend (Next.js) ---
# Must also be set in frontend/.env.local (or the Vercel project's env vars) — Next.js only
# reads .env files from its own project root, not this one.
NEXT_PUBLIC_API_URL=http://localhost:8000
