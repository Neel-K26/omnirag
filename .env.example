# --- Backend (FastAPI) ---
GEMINI_API_KEY=
COHERE_API_KEY=

# Comma-separated list of allowed CORS origins (exact matches, no wildcards).
# Local dev default shown; in production set this to your deployed frontend URL(s),
# e.g. https://omnirag.vercel.app,https://omnirag.com
FRONTEND_URL=http://localhost:3000

# --- Frontend (Next.js) ---
# NOTE: this is now hardcoded as a build-time constant in frontend/next.config.ts and
# will ignore whatever is set here, in frontend/.env.local, or in Vercel's dashboard —
# see frontend/.env.example for why.
NEXT_PUBLIC_API_URL=http://localhost:8000
